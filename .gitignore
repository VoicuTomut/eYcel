# ─────────────────────────────────────────────
# eYcel .gitignore
# ─────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Distribution / Packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# Environment files — keep example, ignore real .env
.env
!.env.example

# eYcel specific outputs — ignore generated files, keep examples
output/
logs/
*.encrypted.xlsx
*_rules.yaml
!examples/*_rules.yaml
!examples/*.encrypted.xlsx

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
nosetests.xml

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Profiling
*.prof
