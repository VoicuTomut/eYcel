# ─────────────────────────────────────────────
# eYcel Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Output directory for encrypted/decrypted files
EYCEL_DEFAULT_OUTPUT_DIR=./output

# Logging configuration
EYCEL_LOG_LEVEL=INFO
EYCEL_LOG_FILE=./logs/eYcel.log

# Security — change this to a strong random string
EYCEL_HASH_SALT=your_random_salt_here

# Performance tuning
EYCEL_CHUNK_SIZE=1000
EYCEL_MAX_MEMORY_MB=50
