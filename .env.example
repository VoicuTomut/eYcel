# eYcel Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit the .env file — it is in .gitignore

# ── Encryption Settings ──────────────────────────────────────────────────────

# Default salt for hashing (override per-run for extra security)
# Leave empty to auto-generate a random salt each run
EYCEL_DEFAULT_SALT=

# Hash algorithm: sha256 (recommended) | sha512 | md5
EYCEL_HASH_ALGORITHM=sha256

# ── File Settings ─────────────────────────────────────────────────────────────

# Default output directory (leave empty to use same dir as input)
EYCEL_OUTPUT_DIR=

# Default rules file name suffix
EYCEL_RULES_SUFFIX=_rules

# ── Performance Settings ──────────────────────────────────────────────────────

# Chunk size for large file processing (rows)
EYCEL_CHUNK_SIZE=1000

# Max memory warning threshold in MB
EYCEL_MAX_MEMORY_MB=50

# ── Logging Settings ──────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR
EYCEL_LOG_LEVEL=INFO

# Log file path (leave empty to log to console only)
EYCEL_LOG_FILE=

# ── Development Settings ──────────────────────────────────────────────────────

# Set to true to enable verbose output during development
EYCEL_DEBUG=false
